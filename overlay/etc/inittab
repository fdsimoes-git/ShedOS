# /etc/inittab — ShedOS

::sysinit:/sbin/openrc sysinit
::sysinit:/sbin/openrc boot
::wait:/sbin/openrc default

# ttyS0 (Fusion virtual serial port, surfaced to the host as a Unix
# socket) is the primary interface. tty1 (Fusion framebuffer) gets the
# same TUI. Both connect to the brain daemon's /run/shedos-brain.sock.
ttyS0::respawn:/sbin/getty -L -n -l /opt/shedos/run-tui.sh -i 115200 ttyS0 vt100
tty1::respawn:/sbin/getty -n -l /opt/shedos/run-tui.sh -i 38400 tty1
tty2::respawn:/sbin/getty 38400 tty2
tty3::respawn:/sbin/getty 38400 tty3
tty4::respawn:/sbin/getty 38400 tty4
tty5::respawn:/sbin/getty 38400 tty5
tty6::respawn:/sbin/getty 38400 tty6

::shutdown:/sbin/openrc shutdown
