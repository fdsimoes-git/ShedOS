# Packages installed to /mnt during install. Drives apk --root --initdb add.
# Lines starting with # are ignored.

# Core
alpine-base
alpine-conf
linux-virt
linux-firmware-none
openrc
busybox-extras
mkinitfs

# Storage / disk maintenance
e2fsprogs
dosfstools
parted

# Bootloader
grub
grub-efi
efibootmgr

# Networking + base userland
openssh
ca-certificates
iproute2
curl

# Brain runtime
python3
py3-httpx

# TUI runtime (v0.3.0+, fallback for serial/ssh access)
py3-prompt_toolkit
py3-rich
# pip needed to install textual (not packaged for Alpine 3.23)
py3-pip

# Web bridge (v0.4.0): aiohttp serves the GUI's HTTP + WebSocket
py3-aiohttp

# GUI stack (v0.4.0): X11 + WM + Chromium app mode on tty1
xorg-server
xinit
mesa-dri-gallium
# xf86-video-vmware is x86-only; use the generic framebuffer driver for arm64
xf86-video-fbdev
xf86-input-libinput
openbox
chromium
chromium-swiftshader
font-jetbrains-mono
font-noto
ttf-dejavu

# Convenience
htop
