# /etc/inittab — ShedOS INSTALLER (on the live ISO)
#
# installer.sh runs only on ttyS0 (Mac-side via `make console`). Two
# parallel installers would race on /dev/sda. tty1 (Fusion window) shows
# a static banner pointing the user at `make console`.

::sysinit:/sbin/openrc sysinit
::sysinit:/sbin/openrc boot
::wait:/sbin/openrc default

# Only ttyS0 runs the installer — we don't want two parallel install
# instances racing on the same /dev/sda. tty1 shows a status banner so the
# user sees something in the Fusion window.
ttyS0::respawn:/sbin/getty -L -n -l /opt/shedos-installer/run-installer.sh -i 115200 ttyS0 vt100
tty1::respawn:/sbin/getty -n -l /opt/shedos-installer/tty1-banner.sh -i 38400 tty1
tty2::respawn:/sbin/getty 38400 tty2
tty3::respawn:/sbin/getty 38400 tty3

::shutdown:/sbin/openrc shutdown
