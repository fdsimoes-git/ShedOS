# /etc/inittab — ShedOS INSTALLER (on the live ISO)
#
# tty1 (the visible Fusion window) runs the wizard — that's what a fresh
# user sees on first boot. ttyS0 stays as a plain getty so it's available
# for debugging via `make console` from the Mac (you can read the install
# log there too if anything goes wrong).
#
# installer.sh holds /run/shedos-installer.lock for the duration of the
# install, so even if a second instance ever spawned (e.g. via tty2) it
# would detect the lock and sleep instead of racing on /dev/sda.

::sysinit:/sbin/openrc sysinit
::sysinit:/sbin/openrc boot
::wait:/sbin/openrc default

# Wizard + installer run on tty1 (visible to the user in the Fusion window).
tty1::respawn:/sbin/getty -n -l /opt/shedos-installer/run-installer.sh -i 38400 tty1
# ttyS0: plain getty for debugging — `make console` lands you in a shell.
ttyS0::respawn:/sbin/getty -L 115200 ttyS0 vt100
tty2::respawn:/sbin/getty 38400 tty2
tty3::respawn:/sbin/getty 38400 tty3

::shutdown:/sbin/openrc shutdown
